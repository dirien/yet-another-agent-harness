{
  "$schema": "https://github.com/dirien/yet-another-agent-harness/yaah.schema.json",
  "version": "1",
  "settings": {
    "model": "opus",
    "alwaysThinkingEnabled": true,
    "effortLevel": "high",
    "autoUpdatesChannel": "latest",
    "statusLine": {
      "type": "command",
      "command": "npx -y ccstatusline@latest",
      "padding": 0
    },
    "enabledPlugins": {
      "example-skills@anthropic-agent-skills": true,
      "python-development@claude-code-workflows": true,
      "context7@claude-plugins-official": true
    },
    "env": {
      "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
    },
    "teammateMode": "tmux"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "yaah hook PostToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session complete'"
          }
        ]
      }
    ]
  },
  "mcp": {
    "servers": [
      {
        "name": "context7",
        "transport": "stdio",
        "command": "npx",
        "args": ["-y", "@context7/mcp"]
      }
    ]
  },
  "skills": {
    "skills": [
      {
        "name": "git-committer",
        "description": "Atomic, semantic-boundary commit workflow",
        "source": ".claude/skills/git-committer/SKILL.md",
        "enabled": true
      }
    ]
  },
  "agents": {
    "agents": [
      {
        "name": "executor",
        "description": "Single-task executor with strict verification",
        "source": ".claude/agents/executor.md",
        "model": "sonnet",
        "permission": "ask"
      }
    ]
  }
}
